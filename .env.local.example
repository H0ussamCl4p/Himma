# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# Supabase project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=

# Service-role key (Supabase dashboard → Project Settings → API → service_role).
# This bypasses Row Level Security. Server-side ONLY — never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Password that gates the /admin page.
ADMIN_PASSWORD=
